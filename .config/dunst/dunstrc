[global]
corner_radius = 8
font = "Ubuntu Nerd Font Medium 13"
frame_color = "#88BBFF"
frame_width = 2
separator_color= frame
dmenu = "/usr/bin/rofi -dmenu"

[urgency_low]
background = "#000000BB"
foreground = "#AAAAAA"

[urgency_normal]
background = "#000000BB"
foreground = "#FFFFFF"

[urgency_critical]
background = "#000000BB"
foreground = "#FFFFFF"
frame_color = "#FF8888"
